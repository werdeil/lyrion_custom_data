# Lyrion Music Server
LYRION_HOST=https://lyrion.local:9000

# Répertoires contenant les fichiers SQLite de Lyrion
# library.db et persist.db sont construits automatiquement depuis ces chemins
DB_DIR=/path/to/squeezeboxserver/cache
DB_PERSIST_DIR=/path/to/squeezeboxserver/prefs

# Custom data / script runner
CUSTOM_DATA_DIR=/opt/scripts/custom_data
CUSTOM_SCRIPT_PATH=/opt/scripts/lms-custom-stats.sh
CUSTOM_TOKEN=2uUdz3lRCsfDCwEzsziu

# Paroles : providers web essayés dans l'ordre, le premier qui répond gagne.
# Valeurs possibles : lrclib, musixmatch, genius
LYRICS_PROVIDERS=lrclib,musixmatch,genius
# Optionnel : token Musixmatch fixe (sinon récupéré automatiquement)
# MUSIXMATCH_TOKEN=

# Flask
SECRET_KEY=change-me-in-production
