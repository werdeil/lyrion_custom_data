# Lyrion Music Server
LYRION_HOST=https://lyrion.local:9000

# Directories holding Lyrion's SQLite files
# library.db and persist.db are derived automatically from these paths
DB_DIR=/path/to/squeezeboxserver/cache
DB_PERSIST_DIR=/path/to/squeezeboxserver/prefs

# Custom data
CUSTOM_DATA_DIR=/opt/scripts/custom_data

# Lyrics: web providers tried in order, the first one that responds wins.
# Possible values: lrclib, musixmatch, genius
LYRICS_PROVIDERS=lrclib,musixmatch,genius
# Optional: fixed Musixmatch token (otherwise fetched automatically)
# MUSIXMATCH_TOKEN=

# Flask
SECRET_KEY=change-me-in-production

# Development: set DEV=1 to live-reload templates and disable static caching,
# so HTML/CSS edits show up on a page refresh without restarting the server.
# DEV=1
